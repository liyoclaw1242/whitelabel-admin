# Sentry — client-side error tracking
# Leave blank to disable Sentry locally; the app starts normally without these.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Required only for source map upload during production builds (CI)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# OpenTelemetry — server-side traces
# Leave blank to disable tracing locally; instrumentation.ts logs a warning
# and the app boots normally. Set OTEL_EXPORTER_OTLP_ENDPOINT to an OTLP/HTTP
# collector (e.g. Axiom, Grafana Cloud OTLP ingest) to enable.
# Headers format: "key1=value1,key2=value2" (used for auth tokens).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Grafana Faro — frontend RUM/error tracking
# Collect URL and app key from the Grafana Cloud Faro onboarding flow.
GRAFANA_FARO_URL=
GRAFANA_FARO_APP_KEY=

# Database — Neon Postgres (pooled connection string)
# Per-branch URLs live in GitHub Actions Secrets (NEON_DEV_URL / NEON_PREVIEW_URL / NEON_PROD_URL).
DATABASE_URL=

# Next.js proxy target — Go serverless function URL.
# Production: apex or /api route. Preview: Vercel preview URL. Dev: localhost:8080.
BACKEND_URL=

# JWT RS256 keypair — per-environment, unique.
# Generated by BE keygen tool (#128). Keep PRIVATE_KEY out of the client bundle.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Cloudflare Workers KV — refresh-token blacklist store.
# Namespace ids: whitelabel-refresh-blacklist-prod / -preview (dev shares preview).
# Token scope: Account → Workers KV Storage: Edit (+ Zone DNS: Read if Resend DNS lives here).
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=

# Resend — transactional email.
# Bind sender domain + DKIM/SPF/DMARC DNS before use. API key scope: sending only.
RESEND_API_KEY=
